# =============================================================================
# MercadoTCG — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores antes de rodar.
# =============================================================================

# ----------------------------------------------------------------------------
# Auth — JWT
# ----------------------------------------------------------------------------

# Chave para assinar JWTs. Obrigatória. Mínimo 32 chars em produção.
# Gerar com: openssl rand -hex 32
JWT_SECRET=troque-para-uma-chave-secreta-de-pelo-menos-32-bytes

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# URL base do frontend (usada nos links dos emails e redirect OAuth).
FRONTEND_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Google OAuth (opcional — se vazio, botão Google retorna 501)
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Chave HMAC para validar o state param do OAuth (32 bytes hex).
# Gerar com: openssl rand -hex 32
OAUTH_STATE_HMAC_KEY=

# ----------------------------------------------------------------------------
# Email — Resend (opcional)
# Sem chave, emails são apenas logados no stdout.
# https://resend.com
# ----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@mercadotcg.com.br

# ----------------------------------------------------------------------------
# Fontes externas — todas opcionais
# Sem elas, a busca externa devolve erro por fonte, mas o restante funciona.
# ----------------------------------------------------------------------------

# PokéWallet — cobre TCGPlayer (USD) e Cardmarket (EUR).
# Conta gratuita em https://pokewallet.io/ (100 req/hora, 1.000/dia).
POKEWALLET_API_KEY=

# eBay (não usado diretamente — graded sales via Scrydex, sem auth).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Pokémon TCG API — importador de catálogo.
# Sem chave: 1.000 req/dia. Com chave (grátis em https://dev.pokemontcg.io/): 20.000/dia.
POKEMON_TCG_API_KEY=

# ----------------------------------------------------------------------------
# Upload de arquivos (dev: diretório local; prod: Cloudflare R2)
# ----------------------------------------------------------------------------
UPLOADS_BASE_URL=http://localhost:8080/uploads
