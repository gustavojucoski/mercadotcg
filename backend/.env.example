APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=info

# Conexão para o Postgres do docker-compose local. Em produção vem do Supabase.
DATABASE_URL=postgres://mercadotcg:mercadotcg@localhost:5432/mercadotcg?sslmode=disable

# Caminho onde golang-migrate procura .sql (relativo ao cwd quando você roda).
MIGRATIONS_PATH=./migrations

# ----------------------------------------------------------------------------
# Auth — JWT + Google OAuth + Resend
# ----------------------------------------------------------------------------

# Chave para assinar JWTs. Obrigatória. Mínimo 32 chars em produção.
# Gerar com: openssl rand -hex 32
JWT_SECRET=troque-para-uma-chave-secreta-de-pelo-menos-32-bytes

# TTL dos tokens (padrão: 15m acesso, 30d refresh).
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=720h

# URL base do frontend (usada nos links dos emails e redirect OAuth).
FRONTEND_BASE_URL=http://localhost:3000

# Google OAuth (opcional — se vazio, botão Google retorna 501).
# Console: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Chave HMAC para validar o state param do OAuth (32 bytes hex).
# Gerar com: openssl rand -hex 32
OAUTH_STATE_HMAC_KEY=

# Resend — envio de emails de verificação e reset de senha.
# Criar conta em https://resend.com e adicionar a API key.
# Se vazio, emails são apenas logados no stdout (modo desenvolvimento).
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@mercadotcg.com.br

# ----------------------------------------------------------------------------
# Credenciais de fontes externas — todas OPCIONAIS.
# Sem elas, o /external-search devolve a fonte com error="source não configurada"
# mas as outras fontes continuam funcionando.
# ----------------------------------------------------------------------------

# PokéWallet (https://pokewallet.io/) — cobre TCGPlayer (USD) e Cardmarket (EUR).
# Crie uma conta gratuita em https://pokewallet.io/ para obter a API key.
# Free tier: 100 req/hora, 1.000/dia. Sem chave, TCGPlayer e Cardmarket retornam vazio.
POKEWALLET_API_KEY=

# eBay — não utilizado diretamente (vendas gradeadas via Scrydex, sem auth).
# Mantido por compatibilidade.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Pokemon TCG API (https://pokemontcg.io/) — opcional.
# Sem chave, rate limit é 1.000 reqs/dia. Com chave (grátis em https://dev.pokemontcg.io/),
# 20.000/dia. O importador de catálogo usa essa.
POKEMON_TCG_API_KEY=
